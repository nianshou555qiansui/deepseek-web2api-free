# DeepSeek API Proxy Configuration
# Copy this file to .env and fill in your credentials

# ── Client API authentication (/v1/*) ────────────────────────
# Required for public deployments. Clients should send either:
#   Authorization: Bearer <key>
# or:
#   x-api-key: <key>
API_KEYS=

# Optional single-key alias, also accepted by /v1/* auth.
# DEEPSEEK_API_KEY=sk-change-me

# Only for local development. Do NOT enable on a public server.
ALLOW_UNAUTHENTICATED_API=false

# ── DeepSeek account credentials ─────────────────────────────
# Get these from browser DevTools -> Network -> any request to chat.deepseek.com
# DEEPSEEK_TOKEN = "Authorization" header value after "Bearer "
# DEEPSEEK_COOKIES = "Cookie" header value

# Numbered multi-account format. Env accounts are loaded on startup and are
# read-only in the web panel; edit .env and restart the service to change them.
DEEPSEEK_TOKEN_1=your_first_token_here
DEEPSEEK_COOKIES_1=your_first_cookies_here
DEEPSEEK_EMAIL_1=first-account

# DEEPSEEK_TOKEN_2=your_second_token_here
# DEEPSEEK_COOKIES_2=your_second_cookies_here
# DEEPSEEK_EMAIL_2=second-account

# Legacy single-account format is still supported.
# DEEPSEEK_TOKEN=your_token_here
# DEEPSEEK_COOKIES=your_cookies_here
# DEEPSEEK_EMAIL=env-default

# Panel-managed accounts are persisted to this JSON file.
# Keep this file private; it contains raw DeepSeek tokens and cookies.
ACCOUNT_STORE_PATH=data/accounts.json

# Server port (default: 8080)
PORT=8080

# Model name shown in API responses (doesn't affect actual model used)
MODEL_NAME=deepseek-chat

# Mode: "auto" (respect client), "quick" (force quick mode), "expert" (force expert mode)
# When set to "expert", all requests use expert mode regardless of client's thinking_mode
# When set to "quick", all requests use quick mode regardless of client's thinking_mode
MODE=auto

# Thinking: "auto" (respect client), "enabled" (force on), "disabled" (force off)
# Controls thinking_enabled independently of mode.
# MODE=quick + THINKING=enabled → quick mode with thinking/reasoning enabled
THINKING=auto

# Search / Web Search: "auto" (respect client), "enabled" (force on), "disabled" (force off)
# Controls search_enabled for web search capability.
SEARCH=auto

# Admin panel password (for /webui management interface)
# If not set, default is "admin". Change this before exposing the service.
DEEPSEEK_ADMIN_PASSWORD=admin
